Affine Cipher. Tools dCode Affine Cipher, Cryptii Affine Cipher.
def affine_encrypt(text, a, b):
    result = ""

    for char in text.upper():
        if char.isalpha():
            x = ord(char) - 65
            result += chr(((a*x+b)%26)+65)

    return result

print(affine_encrypt("HELLO",5,8))

