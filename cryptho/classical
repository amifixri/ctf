Atbash Chiper adalah Huruf dibalik. Tools online dCode Atbash Cipher, Cryptii Atbash.

def atbash(text):
    result = ""

    for c in text.upper():
        if c.isalpha():
            result += chr(ord('Z') - (ord(c) - ord('A')))
        else:
            result += c

    return result

print(atbash("HELLO"))

