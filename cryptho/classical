Caesar Chiper adalah Setiap huruf digeser sejumlah nilai tertentu. Tools Cryptii Caesar Cipher, dCode Caesar Cipher.

def caesar_encrypt(text, shift):
    result = ""

    for char in text:
        if char.isalpha():
            base = ord('A') if char.isupper() else ord('a')
            result += chr((ord(char) - base + shift) % 26 + base)
        else:
            result += char

    return result

print(caesar_encrypt("HELLO", 3))

