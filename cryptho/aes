CTR (Counter Mode) AES digunakan untuk membuat keystream.

from Crypto.Cipher import AES
from Crypto.Util import Counter

key = b"1234567890123456"
nonce = b"12345678"

ctr = Counter.new(
    64,
    prefix=nonce
)

cipher = AES.new(
    key,
    AES.MODE_CTR,
    counter=ctr
)

plaintext = cipher.decrypt(
    bytes.fromhex("YOUR_HEX")
)

print(plaintext.decode())

