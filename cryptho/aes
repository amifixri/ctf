CFB (Cipher Feedback) AES menghasilkan output yang digunakan untuk mengenkripsi plaintext berikutnya.

from Crypto.Cipher import AES

key = b"1234567890123456"
iv = b"abcdefghijklmnop"

cipher = AES.new(
    key,
    AES.MODE_CFB,
    iv=iv
)

plaintext = cipher.decrypt(
    bytes.fromhex("YOUR_HEX")
)

print(plaintext.decode())

