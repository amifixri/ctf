GCM (Galois Counter Mode), Gabungan:
AES CTR
Authentication Tag
from Crypto.Cipher import AES

key = b"1234567890123456"

nonce = bytes.fromhex(
    "00112233445566778899aabb"
)

ciphertext = bytes.fromhex(
    "YOUR_CIPHER"
)

tag = bytes.fromhex(
    "YOUR_TAG"
)

cipher = AES.new(
    key,
    AES.MODE_GCM,
    nonce=nonce
)

plaintext = cipher.decrypt_and_verify(
    ciphertext,
    tag
)

print(plaintext.decode())
